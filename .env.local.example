# ============================================================
# CH Accessoires — Variables d'environnement
# Copier ce fichier en .env.local et remplir toutes les valeurs
# NE JAMAIS committer .env.local dans Git
# ============================================================

# --- Supabase ---
# Récupérer depuis : https://supabase.com/dashboard/project/[ID]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Meta Pixel ---
# Récupérer depuis : https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# --- Meta Conversions API (CAPI) ---
# Générer depuis : Events Manager → Settings → Conversions API
META_CAPI_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optionnel : code de test pour vérifier les événements CAPI en dev
META_TEST_EVENT_CODE=TEST12345

# --- URLs ---
NEXT_PUBLIC_SITE_URL=https://ch-accessoires.com

# --- WhatsApp (numéro algérien sans +) ---
# Format : 213XXXXXXXXX (213 = indicatif Algérie)
NEXT_PUBLIC_WHATSAPP_NUMBER=213XXXXXXXXX

# --- Notifications admin : WhatsApp CallMeBot ---
# Activer sur : https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=XXXXXXXXX
# Votre numéro WhatsApp admin (format international sans +) : 213XXXXXXXXX
ADMIN_WHATSAPP_NUMBER=213XXXXXXXXX

# --- Notifications admin : Email via Resend ---
# Créer un compte sur : https://resend.com → API Keys → Create Key
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Email qui reçoit les notifications admin
ADMIN_EMAIL=admin@ch-accessoires.com

# --- WhatsApp Cloud API (confirmation automatique au CLIENT) ---
# Récupérer depuis : https://developers.facebook.com → App → WhatsApp → API Setup
# Access Token (permanent via System User) :
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Phone Number ID (pas le numéro, l'ID dans Meta Business) :
WHATSAPP_PHONE_ID=1234567890123456
# Nom du template approuvé dans Meta Business Suite :
WHATSAPP_TEMPLATE_NAME=confirmation_commande
