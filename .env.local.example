# ============================================================
# CH Accessoires — Variables d'environnement
# Copier ce fichier en .env.local et remplir toutes les valeurs
# NE JAMAIS committer .env.local dans Git
# ============================================================

# --- Supabase ---
# Récupérer depuis : https://supabase.com/dashboard/project/[ID]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Meta Pixel ---
# Récupérer depuis : https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# --- Meta Conversions API (CAPI) ---
# Générer depuis : Events Manager → Settings → Conversions API
META_CAPI_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optionnel : code de test pour vérifier les événements CAPI en dev
META_TEST_EVENT_CODE=TEST12345

# --- URLs ---
NEXT_PUBLIC_SITE_URL=https://ch-accessoires.com

# --- WhatsApp (numéro algérien sans +) ---
# Format : 213XXXXXXXXX (213 = indicatif Algérie)
NEXT_PUBLIC_WHATSAPP_NUMBER=213XXXXXXXXX
